# Canonical production platform settings applied by prod-release-supabase.sh / Release CI.
# Secrets (SMTP password, Twilio) stay in GitHub Secrets or Supabase dashboard.

PROD_SITE_URL=https://www.ceenaix.com

# Newline-separated redirect allow-list (Supabase Management API: uri_allow_list)
PROD_URI_ALLOW_LIST=$'https://www.ceenaix.com/**\nhttps://ceenaix.com/**\nhttps://*.vercel.app/**\nhttp://localhost:5173/**\nhttp://127.0.0.1:5173/**'
